# ============================================================
# PhishGuard Environment Configuration Template
# ============================================================
#
# COOLIFY SETUP:
# 1. In Coolify → your service → Environment Variables, add each
#    variable below with its real value.
# 2. Variables marked REQUIRED must be set or the app will fail.
# 3. NEVER commit actual secrets to git — only this template file.
#
# LOCAL SETUP:
# 1. Copy to .env.local:  cp .env.example .env.local
# 2. Fill in real values in .env.local
# 3. .env.local is already in .gitignore
# ============================================================

# ── App URLs ──────────────────────────────────────────────────────────────────
# Replace "https://your-domain.com" with your actual production domain.
# In Coolify this is the domain you have assigned to this service.
# REQUIRED
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_API_BASE_URL=https://your-domain.com/api
NEXT_PUBLIC_APP_NAME=PhishGuard

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Must match NEXT_PUBLIC_SITE_URL exactly (no trailing slash).
# REQUIRED
NEXTAUTH_URL=https://your-domain.com

# Generate with:  openssl rand -base64 32
# REQUIRED — change this before deploying!
NEXTAUTH_SECRET=REPLACE_WITH_GENERATED_SECRET

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Use MongoDB Atlas for production (free tier works for small apps).
# Format: mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
# REQUIRED
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/phishguard?retryWrites=true&w=majority

# ── SMTP / Email ──────────────────────────────────────────────────────────────
# Used for verification emails, password resets, and weekly reports.
# REQUIRED for full functionality.
#
# Option 1 — Gmail (easy for testing, enable App Passwords in Google account)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@your-domain.com

# Option 2 — SendGrid (recommended for production)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=apikey
# EMAIL_PASSWORD=your-sendgrid-api-key
# EMAIL_FROM=noreply@your-domain.com

# Option 3 — Custom SMTP
# EMAIL_HOST=mail.your-domain.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
# EMAIL_USER=your-smtp-username
# EMAIL_PASSWORD=your-smtp-password
# EMAIL_FROM=noreply@your-domain.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Authorised redirect URI:  https://your-domain.com/api/auth/callback/google
# REQUIRED for Google login
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# https://github.com/settings/developers → New OAuth App
# Callback URL:  https://your-domain.com/api/auth/callback/github
# REQUIRED for GitHub login
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── JWT (Desktop client auth) ─────────────────────────────────────────────────
# Generate each with:  openssl rand -base64 32
# Use DIFFERENT values for each secret.
# REQUIRED for desktop app support
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_ACCESS_SECRET=REPLACE_WITH_GENERATED_ACCESS_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_GENERATED_REFRESH_SECRET

# Token expiry times in seconds
JWT_ACCESS_EXPIRY=3600
JWT_REFRESH_EXPIRY=2592000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_GLOBAL=10000
RATE_LIMIT_PER_USER=100
RATE_LIMIT_WINDOW_MINUTES=60

# Desktop client scan limits (per hour)
FREE_USER_SCAN_LIMIT=100
PREMIUM_USER_SCAN_LIMIT=1000

# ── URL Scanning APIs ─────────────────────────────────────────────────────────
# Engine 1 (40% weight) — local ML, no API key needed.
# Engine 2 (50% weight) — VirusTotal: https://www.virustotal.com/gui/join-us
ENGINE_2_API_KEY=your-virustotal-api-key
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# Engine 3 (10% weight) — URLScan.io: https://urlscan.io/
ENGINE_3_API_KEY=your-urlscan-api-key
URLSCAN_API_KEY=your-urlscan-api-key

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: info | warning | error | critical
LOG_LEVEL=info
LOG_RETENTION_DAYS=90
ENABLE_CONSOLE_LOGS=true
# Set to true for extra debug output (e.g. repeated DB connection messages)
VERBOSE_LOGS=false

# ── Optional / Analytics ─────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# SENTRY_DSN=your-sentry-dsn

# ── Security reminders ────────────────────────────────────────────────────────
# - Never commit .env.local with real credentials
# - Rotate secrets periodically
# - Use a different NEXTAUTH_SECRET per environment
# - In Coolify, set these via the Environment Variables UI, not in this file

